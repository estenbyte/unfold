---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import Logo from "../components/Logo.astro";

interface Props {
  title: string;
  showSidebar?: boolean;
}

const { title, showSidebar = true } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Unfold</title>
    <meta name="description" content="Complex topics, explained simply. Real code. Real understanding." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cabin+Condensed:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%23fafafa'/><path d='M8 10h16M8 16h12M8 22h8' stroke='%2309090b' stroke-width='2.5' stroke-linecap='round'/></svg>"
    />
  </head>
  <body>
    <!-- Reading progress bar -->
    <div id="read-progress" class="read-progress" aria-hidden="true"></div>

    <!-- Header -->
    <header class="header">
      <div class="header-inner">
        <div class="header-left">
          {showSidebar && (
            <button id="menu-toggle" class="menu-toggle" aria-label="Toggle chapter menu" title="Toggle menu">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7" />
                <rect x="14" y="3" width="7" height="7" />
                <rect x="3" y="14" width="7" height="7" />
                <rect x="14" y="14" width="7" height="7" />
              </svg>
            </button>
          )}
          <Logo size={20} />
        </div>

        <nav class="header-breadcrumb" id="breadcrumb"></nav>

        <div class="header-right">
          <a href="/" class="header-link">Topics</a>
        </div>
      </div>
    </header>

    <!-- Sidebar overlay -->
    <div id="sidebar-overlay" class="sidebar-overlay"></div>

    <!-- Layout -->
    <div class="app-layout">
      {showSidebar && <Fragment><slot name="sidebar"><Sidebar /></slot></Fragment>}
      <main class="main-content">
        <article class="animate-in prose">
          <slot />
        </article>
      </main>
      {showSidebar && (
        <aside id="page-toc" class="page-toc" aria-label="On this page">
          <div class="page-toc-head">On this page</div>
          <ul id="page-toc-list" class="page-toc-list"></ul>
        </aside>
      )}
    </div>

    <!-- Keyboard shortcuts hint -->
    <button id="kbd-hint" class="kbd-hint" aria-label="Show keyboard shortcuts">
      <kbd style="font-family: var(--font-mono); font-size: 0.65rem; padding: 1px 5px; border: 1px solid var(--color-border); border-radius: 4px;">?</kbd>
      shortcuts
    </button>

    <!-- Keyboard shortcuts help modal -->
    <div id="kbd-help" class="kbd-help" role="dialog" aria-modal="true" aria-labelledby="kbd-help-title" hidden>
      <div class="kbd-help-card">
        <div class="kbd-help-head">
          <h2 id="kbd-help-title">Keyboard shortcuts</h2>
          <button class="kbd-help-close" aria-label="Close">✕</button>
        </div>
        <ul class="kbd-help-list">
          <li><span><kbd>j</kbd> / <kbd>k</kbd></span><span>Scroll down / up</span></li>
          <li><span><kbd>n</kbd> / <kbd>p</kbd></span><span>Next / previous chapter</span></li>
          <li><span><kbd>g</kbd></span><span>Jump to top</span></li>
          <li><span><kbd>G</kbd></span><span>Jump to bottom</span></li>
          <li><span><kbd>m</kbd></span><span>Toggle chapter menu</span></li>
          <li><span><kbd>?</kbd></span><span>Show this help</span></li>
          <li><span><kbd>Esc</kbd></span><span>Close menus</span></li>
        </ul>
        <p class="kbd-help-foot">Shortcuts pause when typing in inputs.</p>
      </div>
    </div>

    <style>
      .header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 52px;
        z-index: 50;
        background: rgba(15, 20, 21, 0.85);
        backdrop-filter: saturate(180%) blur(20px);
        -webkit-backdrop-filter: saturate(180%) blur(20px);
        border-bottom: 1px solid var(--color-border-subtle);
      }

      .header-inner {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        max-width: 100%;
      }

      .header-left {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .menu-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: 1px solid var(--color-border);
        color: var(--color-text-muted);
        cursor: pointer;
        padding: 6px;
        border-radius: 8px;
        transition: all 0.15s;
        width: 32px;
        height: 32px;
      }
      .menu-toggle:hover {
        color: var(--color-text-primary);
        background: var(--color-bg-hover);
        border-color: var(--color-text-muted);
      }
      .menu-toggle.active {
        color: var(--color-accent);
        border-color: var(--color-accent);
        background: var(--color-accent-dim);
      }

      .logo-link {
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
      }

      .logo-text {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--color-text-primary);
        letter-spacing: -0.04em;
      }

      .header-breadcrumb {
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        font-weight: 450;
        letter-spacing: -0.01em;
        display: none;
      }

      @media (min-width: 769px) {
        .header-breadcrumb { display: block; }
      }

      .header-right {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .header-link {
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--color-text-muted);
        text-decoration: none;
        padding: 5px 12px;
        border-radius: 6px;
        transition: all 0.15s;
        letter-spacing: -0.01em;
      }
      .header-link:hover {
        color: var(--color-text-primary);
        background: var(--color-bg-hover);
      }

      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 40;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
      }
      .sidebar-overlay.active {
        display: block;
      }

      .app-layout {
        margin-top: 52px;
        min-height: calc(100vh - 52px);
        display: flex;
        justify-content: center;
      }

      .main-content {
        width: 100%;
        max-width: 740px;
        padding: 72px 24px 120px;
        margin: 0 auto;
      }

      @media (max-width: 768px) {
        .main-content {
          padding: 40px 20px 96px;
        }
      }

      @media (min-width: 769px) {
        .main-content {
          padding: 88px 56px 144px;
        }
      }
    </style>

    <script>
      // Sidebar toggle (hidden by default for distraction-free reading)
      const menuToggle = document.getElementById("menu-toggle");
      const sidebar = document.getElementById("sidebar");
      const overlay = document.getElementById("sidebar-overlay");

      function openMenu() {
        sidebar?.classList.remove("-translate-x-full");
        sidebar?.classList.add("translate-x-0");
        overlay?.classList.add("active");
        menuToggle?.classList.add("active");
      }

      function closeMenu() {
        sidebar?.classList.add("-translate-x-full");
        sidebar?.classList.remove("translate-x-0");
        overlay?.classList.remove("active");
        menuToggle?.classList.remove("active");
      }

      menuToggle?.addEventListener("click", () => {
        const isOpen = sidebar?.classList.contains("translate-x-0");
        if (isOpen) closeMenu();
        else openMenu();
      });

      overlay?.addEventListener("click", closeMenu);

      // Close menu on ESC
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeMenu();
      });

      // Code tabs
      document.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest(".code-tab-btn");
        if (!btn) return;
        const container = btn.closest(".code-tabs");
        if (!container) return;
        const lang = btn.getAttribute("data-lang");
        container.querySelectorAll(".code-tab-btn").forEach((b) => b.classList.remove("active"));
        container.querySelectorAll(".code-tab-panel").forEach((p) => p.classList.remove("active"));
        btn.classList.add("active");
        container.querySelector(`.code-tab-panel[data-lang="${lang}"]`)?.classList.add("active");
      });

      // Copy buttons
      document.addEventListener("click", async (e) => {
        const btn = (e.target as HTMLElement).closest(".copy-btn") as HTMLElement;
        if (!btn) return;
        const pre = btn.parentElement?.querySelector("pre");
        if (!pre) return;
        await navigator.clipboard.writeText(pre.textContent || "");
        const original = btn.textContent;
        btn.textContent = "Copied";
        btn.style.color = "var(--color-green)";
        btn.style.borderColor = "var(--color-green)";
        setTimeout(() => {
          btn.textContent = original;
          btn.style.color = "";
          btn.style.borderColor = "";
        }, 2000);
      });

      // ===== Reading progress bar =====
      const progress = document.getElementById("read-progress");
      const article = document.querySelector("article.prose");
      function updateProgress() {
        if (!progress || !article) return;
        const rect = (article as HTMLElement).getBoundingClientRect();
        const top = window.scrollY + rect.top;
        const total = (article as HTMLElement).offsetHeight - window.innerHeight;
        const passed = Math.min(Math.max(window.scrollY - top, 0), Math.max(total, 1));
        const pct = total > 0 ? (passed / total) * 100 : 0;
        progress.style.width = pct + "%";
        if (pct > 95) progress.classList.add("done");
        else progress.classList.remove("done");
      }
      window.addEventListener("scroll", updateProgress, { passive: true });
      window.addEventListener("resize", updateProgress);
      updateProgress();

      // ===== Right-rail TOC (scrollspy) =====
      const tocList = document.getElementById("page-toc-list") as HTMLUListElement | null;
      const tocBox = document.getElementById("page-toc");
      if (tocList && article) {
        const headings = Array.from(
          (article as HTMLElement).querySelectorAll<HTMLElement>("h2"),
        ).filter((h) => h.textContent && h.textContent.trim().length > 0);

        if (headings.length < 2) {
          tocBox?.setAttribute("hidden", "");
        } else {
          headings.forEach((h) => {
            if (!h.id) {
              const slug = (h.textContent || "")
                .toLowerCase().trim()
                .replace(/[^\w\s-]/g, "")
                .replace(/\s+/g, "-")
                .replace(/-+/g, "-");
              h.id = slug;
            }
            const li = document.createElement("li");
            const a = document.createElement("a");
            a.href = "#" + h.id;
            a.dataset.targetId = h.id;
            // strip trailing anchor link text content if present
            const text = (h.firstChild?.nodeType === Node.TEXT_NODE ? h.firstChild.textContent : h.textContent) || "";
            a.textContent = text.replace(/#$/, "").trim();
            li.appendChild(a);
            tocList.appendChild(li);
          });

          // scrollspy
          const links = Array.from(tocList.querySelectorAll<HTMLAnchorElement>("a"));
          const setActive = (id: string) => {
            links.forEach((l) => {
              if (l.dataset.targetId === id) l.classList.add("active");
              else l.classList.remove("active");
            });
          };

          const observer = new IntersectionObserver(
            (entries) => {
              const visible = entries
                .filter((e) => e.isIntersecting)
                .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
              if (visible.length) {
                setActive((visible[0].target as HTMLElement).id);
              }
            },
            { rootMargin: "-80px 0px -65% 0px", threshold: 0 },
          );
          headings.forEach((h) => observer.observe(h));
        }
      }

      // ===== Anchor links on H2/H3 =====
      function slugify(s: string) {
        return s.toLowerCase().trim()
          .replace(/[^\w\s-]/g, "")
          .replace(/\s+/g, "-")
          .replace(/-+/g, "-");
      }
      document.querySelectorAll<HTMLElement>("article.prose h2, article.prose h3").forEach((h) => {
        if (!h.id) h.id = slugify(h.textContent || "");
        if (!h.id) return;
        const a = document.createElement("a");
        a.href = "#" + h.id;
        a.className = "heading-anchor";
        a.setAttribute("aria-label", "Link to this section");
        a.textContent = "#";
        a.addEventListener("click", (e) => {
          e.preventDefault();
          const url = location.origin + location.pathname + "#" + h.id;
          history.replaceState(null, "", "#" + h.id);
          navigator.clipboard?.writeText(url).catch(() => {});
          a.classList.add("copied");
          setTimeout(() => a.classList.remove("copied"), 1200);
        });
        h.appendChild(a);
      });

      // ===== Keyboard shortcuts =====
      const helpModal = document.getElementById("kbd-help");
      function openHelp() { helpModal?.removeAttribute("hidden"); }
      function closeHelp() { helpModal?.setAttribute("hidden", ""); }
      helpModal?.querySelector(".kbd-help-close")?.addEventListener("click", closeHelp);
      helpModal?.addEventListener("click", (e) => {
        if (e.target === helpModal) closeHelp();
      });
      document.getElementById("kbd-hint")?.addEventListener("click", openHelp);

      function isTyping() {
        const el = document.activeElement;
        if (!el) return false;
        const tag = el.tagName;
        return tag === "INPUT" || tag === "TEXTAREA" || (el as HTMLElement).isContentEditable;
      }

      document.addEventListener("keydown", (e) => {
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        if (isTyping()) return;

        if (e.key === "Escape") {
          closeHelp();
          closeMenu();
          return;
        }
        if (e.key === "?") { e.preventDefault(); openHelp(); return; }
        if (e.key === "j") { window.scrollBy({ top: window.innerHeight * 0.4, behavior: "smooth" }); return; }
        if (e.key === "k") { window.scrollBy({ top: -window.innerHeight * 0.4, behavior: "smooth" }); return; }
        if (e.key === "g") { window.scrollTo({ top: 0, behavior: "smooth" }); return; }
        if (e.key === "G") { window.scrollTo({ top: document.body.scrollHeight, behavior: "smooth" }); return; }
        if (e.key === "m") { e.preventDefault(); const isOpen = sidebar?.classList.contains("translate-x-0"); if (isOpen) closeMenu(); else openMenu(); return; }
        if (e.key === "n") {
          const a = document.querySelector<HTMLAnchorElement>(".ch-nav-next");
          if (a?.href) location.href = a.href;
          return;
        }
        if (e.key === "p") {
          const a = document.querySelector<HTMLAnchorElement>(".ch-nav-prev");
          if (a?.href) location.href = a.href;
          return;
        }
      });
    </script>
  </body>
</html>
