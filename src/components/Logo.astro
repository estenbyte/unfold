---
interface Props {
  size?: number;
  href?: string | null;
  variant?: "full" | "mark";
}
const { size = 22, href = "/", variant = "full" } = Astro.props;
const Tag = href ? "a" : "span";
---

<Tag class="logo" href={href ?? undefined}>
  <span class="logo-mark" aria-hidden="true" style={`width: ${size}px; height: ${size}px;`}>
    <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round">
      <line x1="4" y1="7" x2="20" y2="7" />
      <line x1="4" y1="13" x2="16" y2="13" />
      <line x1="4" y1="19" x2="12" y2="19" />
    </svg>
  </span>
  {variant === "full" && <span class="logo-word">Unfold</span>}
</Tag>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    color: var(--color-text-primary);
    transition: opacity 0.15s;
  }
  a.logo:hover { opacity: 0.85; }
  a.logo:hover .logo-mark svg { transform: translateX(1px); }

  .logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .logo-mark svg {
    width: 100%;
    height: 100%;
    stroke: var(--color-accent);
    stroke-width: 2.4;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  /* The unfold-on-load animation: lines widen from collapsed to full */
  .logo-mark svg line {
    transform-origin: center;
    animation: unfold-line 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .logo-mark svg line:nth-child(1) { animation-delay: 0s; }
  .logo-mark svg line:nth-child(2) { animation-delay: 0.08s; }
  .logo-mark svg line:nth-child(3) { animation-delay: 0.16s; }

  @keyframes unfold-line {
    from { transform: scaleX(0); opacity: 0; }
    to   { transform: scaleX(1); opacity: 1; }
  }

  .logo-word {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.04em;
    line-height: 1;
  }
</style>
