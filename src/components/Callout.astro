---
interface Props {
  type?: "info" | "tip" | "warning";
  title?: string;
}

const { type = "info", title } = Astro.props;

const icons: Record<string, string> = {
  info: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>`,
  tip: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
  warning: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
};

const colors: Record<string, string> = {
  info: "var(--color-accent)",
  tip: "var(--color-green)",
  warning: "var(--color-yellow)",
};
---

<div class={`callout callout-${type}`}>
  <div class="flex items-start gap-3">
    <span style={`color: ${colors[type]}; flex-shrink: 0; margin-top: 2px;`} set:html={icons[type]} />
    <div>
      {title && <div class="font-semibold text-sm mb-1" style="color: var(--color-text-primary);">{title}</div>}
      <div class="text-sm" style="color: var(--color-text-secondary); line-height: 1.6;">
        <slot />
      </div>
    </div>
  </div>
</div>
