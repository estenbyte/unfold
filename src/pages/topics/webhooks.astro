---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { webhooksLevels, getWebhooksChaptersSorted } from "../../data/webhooks";

const allChapters = await getWebhooksChaptersSorted();
---

<BaseLayout title="Webhooks" showSidebar={false}>
  <header class="topic-header">
    <a href="/" class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      All topics
    </a>
    <h1 class="topic-title">Webhooks</h1>
    <p class="topic-desc">Sign payloads, verify signatures, retry with backoff, replay protect, idempotency keys. The patterns nobody tells you.</p>
    <div class="topic-stats">
      <span class="stat">{allChapters.length} {allChapters.length === 1 ? "chapter" : "chapters"}</span>
    </div>
  </header>

  {webhooksLevels.map((level) => {
    const items = allChapters.filter((c) => c.data.level === level.key);
    if (items.length === 0) return null;
    return (
      <section class="level-section">
        <div class="level-label">
          <span class="level-dot" style={`background: ${level.color};`} />
          <span class="level-name">{level.label}</span>
          <span class="level-count">{items.length}</span>
        </div>
        <div class="chapter-list">
          {items.map((ch) => (
            <a href={`/webhooks/${ch.id}/`} class="chapter-item">
              <span class="ch-num" style={`color: ${level.color};`}>{String(ch.data.chapter).padStart(2, "0")}</span>
              <div class="ch-info">
                <span class="ch-name">{ch.data.title}</span>
                <span class="ch-desc">{ch.data.subtitle}</span>
              </div>
              <span class="ch-time">{ch.data.readingTime}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ch-arrow"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>

<style>
  .topic-header { margin-bottom: 4rem; padding-bottom: 2.75rem; border-bottom: 1px solid var(--color-border-subtle); }
  .back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 0.8125rem; font-weight: 500; color: var(--color-text-muted); text-decoration: none; margin-bottom: 1.75rem; transition: color 0.15s; }
  .back-link:hover { color: var(--color-text-primary); }
  .topic-title { font-size: 2.25rem; font-weight: 800; letter-spacing: -0.035em; color: var(--color-text-primary); margin: 0 0 1rem; line-height: 1.15; }
  .topic-desc { font-size: 1.0625rem; color: var(--color-text-secondary); line-height: 1.75; margin: 0 0 2rem; }
  .topic-stats { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  .stat { font-size: 0.75rem; font-weight: 500; color: var(--color-text-muted); font-family: var(--font-mono); }
  .level-section { margin-bottom: 3rem; }
  .level-label { display: flex; align-items: center; gap: 9px; padding: 0 0 14px; }
  .level-dot { width: 6px; height: 6px; border-radius: 50%; }
  .level-name { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-muted); }
  .level-count { font-size: 0.625rem; color: var(--color-text-muted); opacity: 0.5; font-family: var(--font-mono); margin-left: auto; }
  .chapter-list { border: 1px solid var(--color-border); border-radius: 14px; overflow: hidden; }
  .chapter-item { display: flex; align-items: center; gap: 18px; padding: 18px 22px; text-decoration: none; transition: background 0.12s; border-bottom: 1px solid var(--color-border-subtle); }
  .chapter-item:last-child { border-bottom: none; }
  .chapter-item:hover { background: var(--color-bg-hover); }
  .chapter-item:hover .ch-arrow { transform: translateX(3px); color: var(--color-accent); opacity: 1; }
  .ch-num { font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600; flex-shrink: 0; width: 24px; letter-spacing: -0.02em; }
  .ch-info { flex: 1; min-width: 0; }
  .ch-name { display: block; font-size: 0.9375rem; font-weight: 550; color: var(--color-text-primary); letter-spacing: -0.015em; line-height: 1.4; }
  .ch-desc { display: block; font-size: 0.78125rem; color: var(--color-text-muted); margin-top: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; line-height: 1.5; }
  .ch-time { font-size: 0.6875rem; color: var(--color-text-muted); font-family: var(--font-mono); flex-shrink: 0; opacity: 0; transition: opacity 0.15s; }
  .chapter-item:hover .ch-time { opacity: 1; }
  .ch-arrow { color: var(--color-text-muted); flex-shrink: 0; transition: all 0.2s; opacity: 0; }
  @media (max-width: 640px) { .topic-title { font-size: 1.625rem; } .ch-desc { display: none; } .ch-arrow { opacity: 0.4; } .ch-time { opacity: 0.6; } .chapter-item { padding: 15px 18px; } }
</style>
