---
import "../styles/global.css";
import { getCollection } from "astro:content";
import Footer from "../components/Footer.astro";
import Logo from "../components/Logo.astro";

// Collections we have any content in
const collections = [
  "chapters",
  "dsa",
  "networking",
  "db-internals",
  "devops",
  "api-design",
  "frontend",
  "golang",
  "sre",
  "linux-vps",
  "web-server",
  "tls-certs",
  "graphql",
  "grpc",
  "websockets",
  "webhooks",
] as const;

const all = await Promise.all(collections.map((c) => getCollection(c as any)));
const counts: Record<string, number> = {};
collections.forEach((name, i) => (counts[name] = all[i].length));

const chaptersByCollection = (name: string) => counts[name] ?? 0;

// total chapters across tracks (excluding chapter==0 roadmaps)
const totalChapters = all.reduce(
  (sum, items) => sum + items.filter((it: any) => it.data.chapter > 0).length,
  0,
);

// rough reading time: each chapter is ~12 min average
const totalMinutes = totalChapters * 12;
const totalHours = Math.round(totalMinutes / 60);

const topics = [
  {
    slug: "system-design",
    title: "System Design",
    desc: "From client-server basics to distributed systems at scale. Includes 7 case studies, 2 step-by-step tutorials, and real code in TypeScript and Go.",
    chapters: chaptersByCollection("chapters"),
    href: "/topics/system-design/",
  },
  {
    slug: "dsa",
    title: "Data Structures & Algorithms",
    desc: "Patterns that show up in real codebases, not leetcode puzzles. Arrays, trees, graphs, DP — with working TypeScript code.",
    chapters: chaptersByCollection("dsa"),
    href: "/topics/dsa/",
  },
  {
    slug: "networking",
    title: "Networking Fundamentals",
    desc: "DNS, TCP/IP, TLS, HTTP/2, WebSockets — how the internet actually works.",
    chapters: chaptersByCollection("networking"),
    href: "/topics/networking/",
  },
  {
    slug: "db-internals",
    title: "Database Internals",
    desc: "B-trees, WAL, MVCC, query planning — what happens under the hood.",
    chapters: chaptersByCollection("db-internals"),
    href: "/topics/db-internals/",
  },
  {
    slug: "devops",
    title: "DevOps & Infrastructure",
    desc: "Docker, Kubernetes, CI/CD, IaC — shipping code to production.",
    chapters: chaptersByCollection("devops"),
    href: "/topics/devops/",
  },
  {
    slug: "api-design",
    title: "API Design",
    desc: "REST best practices, GraphQL, gRPC, versioning, pagination, and rate limiting.",
    chapters: chaptersByCollection("api-design"),
    href: "/topics/api-design/",
  },
  {
    slug: "frontend",
    title: "Frontend Architecture",
    desc: "Rendering patterns (SSR/SSG/ISR), state management, performance, and accessibility.",
    chapters: chaptersByCollection("frontend"),
    href: "/topics/frontend/",
  },
  {
    slug: "golang",
    title: "Go (Golang)",
    desc: "From zero to production Go — types, concurrency, error handling, and patterns used at Google, Uber, and Cloudflare.",
    chapters: chaptersByCollection("golang"),
    href: "/topics/golang/",
  },
  {
    slug: "sre",
    title: "Site Reliability Engineering",
    desc: "SLOs, error budgets, on-call, postmortems, chaos, and disaster recovery — keeping production alive at scale.",
    chapters: chaptersByCollection("sre"),
    href: "/topics/sre/",
  },
];

const pathCore = [
  { n: 1, title: "Linux & VPS basics", desc: "Processes, sockets, systemd, iptables. Rent a VPS, ssh in.", href: "/topics/linux-vps/", done: true },
  { n: 2, title: "Networking essentials", desc: "TCP/UDP, DNS, HTTP from raw socket.", href: "/topics/networking/", done: true },
  { n: 3, title: "Web server fundamentals", desc: "Build minimal HTTP server. Then nginx reverse proxy.", href: "/topics/web-server/", done: true },
  { n: 4, title: "TLS & certs", desc: "Self-sign, then Let's Encrypt with certbot. No managed services.", href: "/topics/tls-certs/", done: true },
  { n: 5, title: "REST API building", desc: "Routing, verbs, status codes, validation, errors, pagination, idempotency.", href: "/topics/api-design/", done: true },
  { n: 6, title: "GraphQL building", desc: "Schema, resolvers, N+1, dataloader. Self-host.", href: "/topics/graphql/", done: true },
  { n: 7, title: "gRPC building", desc: "Proto, codegen, unary + streaming.", href: "/topics/grpc/", done: true },
  { n: 8, title: "WebSockets & realtime", desc: "Long-poll → SSE → WS. Build a chat.", href: "/topics/websockets/", done: true },
  { n: 9, title: "Webhooks", desc: "Sign, verify, retry, replay protect.", href: "/topics/webhooks/", done: true },
  { n: 10, title: "Data modeling", desc: "Schema, normalization, ER, keys, constraints.", href: "/topics/data-modeling/", done: false },
  { n: 11, title: "Databases self-hosted", desc: "Install Postgres on VPS. Transactions, indexes, EXPLAIN.", href: "/topics/db-internals/", done: true },
  { n: 12, title: "Auth & security", desc: "Sessions, argon2, OAuth flows, CSRF, rate limit by hand.", href: "/topics/auth-security/", done: false },
  { n: 13, title: "API gateway", desc: "Own one with nginx/Kong/Envoy. Auth, rate limit, route.", href: "/topics/api-gateway/", done: false },
  { n: 14, title: "Caching", desc: "In-process LRU first. Self-host Redis. Eviction, invalidation, stampede.", href: "/topics/caching/", done: false },
  { n: 15, title: "Background jobs", desc: "Worker loop + Postgres/Redis queue. Retry, DLQ, idempotency.", href: "/topics/background-jobs/", done: false },
  { n: 16, title: "Messaging & queues", desc: "Self-host RabbitMQ/NATS. Then Kafka cluster on 3 VPS.", href: "/topics/messaging/", done: false },
  { n: 17, title: "Event-driven & streaming", desc: "Pub/sub, CDC with Debezium, event sourcing.", href: "/topics/event-driven/", done: false },
  { n: 18, title: "File & object storage", desc: "Local disk → NFS → self-host MinIO. CDN via nginx + Varnish.", href: "/topics/storage/", done: false },
  { n: 19, title: "Search", desc: "Inverted index from scratch. Then self-host Meilisearch/Elastic.", href: "/topics/search/", done: false },
  { n: 20, title: "Load balancing", desc: "HAProxy/nginx. L4 vs L7, health checks, sticky sessions.", href: "/topics/load-balancing/", done: false },
  { n: 21, title: "Horizontal scaling", desc: "Multiple app VPS behind LB. Stateless app, shared session store.", href: "/topics/horizontal-scaling/", done: false },
  { n: 22, title: "Replication & sharding", desc: "Postgres streaming replica by hand. Manual shard routing.", href: "/topics/replication-sharding/", done: false },
  { n: 23, title: "Observability", desc: "Logs (journald), Prometheus + Grafana, Jaeger/OTel traces. Self-hosted.", href: "/topics/observability/", done: false },
];

const pathSpecialized = [
  { n: 24, title: "CI/CD", desc: "Git hooks → self-hosted Gitea Actions / Drone. Build, test, deploy.", href: "/topics/devops/", done: true },
  { n: 25, title: "Containers", desc: "Docker fundamentals, image layers, registry self-host.", href: "/topics/containers/", done: false },
  { n: 26, title: "Orchestration", desc: "k3s cluster across own VPS. Not EKS/GKE.", href: "/topics/orchestration/", done: false },
  { n: 27, title: "Infrastructure as Code", desc: "Ansible playbooks → Terraform against own infra.", href: "/topics/iac/", done: false },
  { n: 28, title: "Testing strategy", desc: "Unit, integration, contract, e2e. Load test with k6/wrk.", href: "/topics/testing/", done: false },
  { n: 29, title: "Performance engineering", desc: "Profile (pprof, perf), flamegraphs, latency budgets.", href: "/topics/performance/", done: false },
  { n: 30, title: "SRE practices", desc: "SLO, error budget, on-call, postmortem, runbook.", href: "/topics/sre/", done: true },
  { n: 31, title: "Disaster recovery", desc: "pg_dump, WAL-G, restore drills, multi-region replica.", href: "/topics/disaster-recovery/", done: false },
  { n: 32, title: "Capacity & cost", desc: "Bare metal vs VPS vs cloud math. Sizing.", href: "/topics/capacity-cost/", done: false },
  { n: 33, title: "Microservices", desc: "When to split, gRPC, service discovery (Consul), Envoy/Linkerd.", href: "/topics/microservices/", done: false },
  { n: 34, title: "Chaos & resilience", desc: "kill -9, pumba, network partition tests.", href: "/topics/chaos-resilience/", done: false },
];

const pathGroups = [
  {
    label: "Fundamentals & core",
    blurb: "Build a working backend on a VPS, end to end. Each step assumes the one before it.",
    steps: pathCore,
  },
  {
    label: "Specialized & operations",
    blurb: "Once the system is alive — operate it, scale it, keep it alive when things break.",
    steps: pathSpecialized,
  },
];

const totalSteps = pathCore.length + pathSpecialized.length;
const doneSteps = [...pathCore, ...pathSpecialized].filter((s) => s.done).length;

const upcoming = [
  { title: "Operating Systems", desc: "Processes, threads, memory management, file systems, and syscalls — how your code actually runs." },
  { title: "Security & Cryptography", desc: "Auth patterns, OAuth, JWT, encryption, and common vulnerabilities — building secure systems." },
  { title: "Distributed Systems", desc: "CAP theorem, consensus (Raft/Paxos), CRDTs, vector clocks, and gossip protocols." },
  { title: "Compiler Design", desc: "Lexing, parsing, ASTs, type checking, and code generation — how languages work." },
  { title: "Machine Learning Fundamentals", desc: "Linear algebra, gradient descent, neural nets, and transformers — for engineers, not researchers." },
  { title: "System Design Interview", desc: "Structured approach to open-ended design questions with worked examples." },
  { title: "Software Architecture Patterns", desc: "Monolith vs microservices, event-driven, hexagonal, CQRS — choosing the right architecture." },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Unfold — Complex topics, explained simply</title>
    <meta name="description" content="Unfold breaks down complex engineering topics into clear explanations with real, working code. No jargon. No hand-waving." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cabin+Condensed:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%23fafafa'/><path d='M8 10h16M8 16h12M8 22h8' stroke='%2309090b' stroke-width='2.5' stroke-linecap='round'/></svg>"
    />
  </head>
  <body>

    <!-- Nav -->
    <nav class="landing-nav">
      <Logo size={22} />
      <div class="nav-right">
        <a href="#path" class="nav-link">Path</a>
        <a href="#topics" class="nav-link">Topics</a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-eyebrow">
          <span class="eyebrow-dot"></span>
          <span>Self-hosted backend, end to end</span>
        </div>
        <h1 class="hero-title">
          Hard things,<br/>
          <span class="hero-accent">unfolded</span>.
        </h1>
        <p class="hero-desc">
          A long-form engineering library. Real code, vendor-neutral, no hand-waving. Pick a topic and read end to end — or follow the Backend Engineering Path step by step.
        </p>

        <div class="scope-strip">
          <a href="#path" class="scope-pill">
            <span class="scope-num">{totalSteps}</span>
            <span class="scope-label">step path</span>
          </a>
          <span class="scope-sep"></span>
          <a href="#topics" class="scope-pill">
            <span class="scope-num">{topics.length}</span>
            <span class="scope-label">topics</span>
          </a>
          <span class="scope-sep"></span>
          <a href="#topics" class="scope-pill">
            <span class="scope-num">{totalChapters}</span>
            <span class="scope-label">chapters</span>
          </a>
          <span class="scope-sep"></span>
          <a href="#topics" class="scope-pill">
            <span class="scope-num">~{totalHours}h</span>
            <span class="scope-label">reading</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Backend Engineering Path -->
    <section id="path" class="path-section">
      <div class="path-inner">
        <header class="section-head">
          <span class="section-eyebrow">Backend engineering path</span>
          <h2 class="section-title">From a blank VPS to a production backend</h2>
          <p class="section-desc">
            {totalSteps} sequential steps, self-hosted from start to finish. Each one builds on the last. {doneSteps} are written; the rest land one by one.
          </p>
        </header>

        {pathGroups.map((group, gi) => (
          <div class="path-group">
            <div class="path-group-head">
              <span class="path-group-num">{gi + 1}</span>
              <div class="path-group-text">
                <span class="path-group-label">{group.label}</span>
                <span class="path-group-blurb">{group.blurb}</span>
              </div>
              <span class="path-group-count">{group.steps.length} steps</span>
            </div>
            <ol class="track">
              {group.steps.map((step) => (
                <li class={`track-item${step.done ? " done" : ""}`}>
                  <a href={step.href} class="track-link">
                    <span class="track-dot" aria-hidden="true">
                      {step.done && (
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      )}
                    </span>
                    <span class="track-num">{String(step.n).padStart(2, "0")}</span>
                    <span class="track-info">
                      <span class="track-title">{step.title}</span>
                      <span class="track-desc">{step.desc}</span>
                    </span>
                    <span class="track-status">
                      {step.done ? (
                        <span class="status-pill status-done">Read</span>
                      ) : (
                        <span class="status-pill status-soon">Soon</span>
                      )}
                    </span>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="track-arrow"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                </li>
              ))}
            </ol>
          </div>
        ))}
      </div>
    </section>

    <!-- Available Topics -->
    <section id="topics" class="topics">
      <div class="topics-inner">
        <header class="section-head">
          <span class="section-eyebrow">Topics</span>
          <h2 class="section-title">{topics.length} libraries to read end to end</h2>
          <p class="section-desc">
            Each topic is a self-contained track of chapters. Read in order or jump to what you need.
          </p>
        </header>

        <div class="topics-grid">
          {topics.map((topic) => (
            <a href={topic.href} class="topic-card">
              <div class="topic-info">
                <span class="topic-title">{topic.title}</span>
                <span class="topic-desc">{topic.desc}</span>
              </div>
              <div class="topic-meta">
                <span class="topic-count">{topic.chapters} ch</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="topic-arrow"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>

        {upcoming.length > 0 && (
          <Fragment>
            <header class="section-head section-head-sub">
              <span class="section-eyebrow">Coming soon</span>
            </header>
            <div class="topics-grid">
              {upcoming.map((topic) => (
                <div class="topic-card topic-card-disabled">
                  <div class="topic-info">
                    <span class="topic-title">{topic.title}</span>
                    <span class="topic-desc">{topic.desc}</span>
                  </div>
                  <div class="topic-meta">
                    <span class="topic-soon-badge">Soon</span>
                  </div>
                </div>
              ))}
            </div>
          </Fragment>
        )}
      </div>
    </section>

    <Footer />

  </body>
</html>

<style>
  body {
    font-family: "Cabin Condensed", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    background: #0f1415;
    color: #fafafa;
    -webkit-font-smoothing: antialiased;
    line-height: 1.6;
    margin: 0;
  }

  ::selection { background: #a3e635; color: #0f1415; }

  /* Nav */
  .landing-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 32px;
    max-width: 1180px;
    margin: 0 auto;
  }
  .nav-right { display: flex; align-items: center; gap: 18px; }
  .nav-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: #71717a;
    text-decoration: none;
    transition: color 0.15s;
    letter-spacing: -0.01em;
  }
  .nav-link:hover { color: #fafafa; }

  @media (max-width: 640px) { .landing-nav { padding: 14px 18px; } }

  /* Hero */
  .hero {
    padding: 72px 32px 80px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    /* faint grid background */
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(163, 230, 53, 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(163, 230, 53, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 70% 80% at 30% 20%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 70% 80% at 30% 20%, black 30%, transparent 80%);
    pointer-events: none;
  }
  @media (max-width: 640px) { .hero { padding: 48px 18px 60px; } }

  .hero-inner {
    max-width: 920px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px 5px 10px;
    background: rgba(163, 230, 53, 0.08);
    border: 1px solid rgba(163, 230, 53, 0.18);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: #a3e635;
    margin-bottom: 28px;
    font-family: "Geist Mono", monospace;
    letter-spacing: -0.005em;
  }
  .eyebrow-dot {
    width: 6px;
    height: 6px;
    background: #a3e635;
    border-radius: 50%;
    box-shadow: 0 0 8px #a3e635;
    animation: pulse 2.4s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-title {
    font-size: clamp(2.5rem, 7vw, 4.75rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.05em;
    color: #fafafa;
    margin: 0 0 24px;
  }
  .hero-accent {
    color: #a3e635;
    font-style: italic;
    font-weight: 700;
    letter-spacing: -0.045em;
  }

  .hero-desc {
    font-size: 1.125rem;
    color: #a1a1aa;
    line-height: 1.65;
    margin: 0 0 36px;
    max-width: 600px;
  }
  @media (max-width: 640px) { .hero-desc { font-size: 1rem; } }

  /* Scope strip */
  .scope-strip {
    display: inline-flex;
    align-items: stretch;
    gap: 0;
    padding: 4px;
    background: #16161a;
    border: 1px solid #27272a;
    border-radius: 14px;
    flex-wrap: wrap;
  }
  .scope-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .scope-pill:hover { background: #1f1f23; }
  .scope-num {
    font-family: "Geist Mono", monospace;
    font-size: 1.125rem;
    font-weight: 700;
    color: #fafafa;
    letter-spacing: -0.04em;
  }
  .scope-label {
    font-size: 0.75rem;
    color: #71717a;
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .scope-sep {
    width: 1px;
    background: #27272a;
    align-self: stretch;
    margin: 8px 0;
  }
  @media (max-width: 640px) {
    .scope-strip { display: flex; }
    .scope-num { font-size: 1rem; }
  }

  /* Section heads */
  .section-head {
    margin-bottom: 32px;
    max-width: 720px;
  }
  .section-head-sub {
    margin-top: 56px;
    margin-bottom: 16px;
  }
  .section-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: #a3e635;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 10px;
    font-family: "Geist Mono", monospace;
  }
  .section-title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 700;
    color: #fafafa;
    letter-spacing: -0.03em;
    margin: 0 0 12px;
    line-height: 1.15;
  }
  .section-desc {
    font-size: 1rem;
    color: #a1a1aa;
    line-height: 1.6;
    margin: 0;
  }

  /* PATH — vertical track */
  .path-section {
    padding: 32px 32px 72px;
  }
  @media (max-width: 640px) { .path-section { padding: 24px 18px 56px; } }
  .path-inner {
    max-width: 1180px;
    margin: 0 auto;
  }

  .path-group {
    margin-bottom: 56px;
    position: relative;
  }
  .path-group:last-child { margin-bottom: 0; }

  .path-group-head {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 0 22px;
    margin-bottom: 8px;
    border-bottom: 1px solid #1f1f23;
  }
  .path-group-num {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: rgba(163, 230, 53, 0.1);
    border: 1px solid rgba(163, 230, 53, 0.3);
    color: #a3e635;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Geist Mono", monospace;
    font-size: 0.875rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .path-group-text { flex: 1; min-width: 0; }
  .path-group-label {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: #fafafa;
    letter-spacing: -0.02em;
  }
  .path-group-blurb {
    display: block;
    font-size: 0.8125rem;
    color: #71717a;
    margin-top: 3px;
    line-height: 1.5;
  }
  .path-group-count {
    font-family: "Geist Mono", monospace;
    font-size: 0.75rem;
    color: #52525b;
    flex-shrink: 0;
  }

  /* Track */
  .track {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }
  /* connecting vertical line */
  .track::before {
    content: "";
    position: absolute;
    left: 17px;
    top: 12px;
    bottom: 12px;
