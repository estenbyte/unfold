---
import "../styles/global.css";
import { getCollection } from "astro:content";
import Footer from "../components/Footer.astro";

const chapters = (await getCollection("chapters")).sort(
  (a, b) => a.data.chapter - b.data.chapter
);

// Group by topic (for now just system design, but extensible)
const dsaChapters = (await getCollection("dsa")).sort(
  (a, b) => a.data.chapter - b.data.chapter
);

const networkingChapters = (await getCollection("networking")).sort(
  (a, b) => a.data.chapter - b.data.chapter
);

const dbChapters = (await getCollection("db-internals")).sort(
  (a, b) => a.data.chapter - b.data.chapter
);

const devopsChapters = (await getCollection("devops")).sort(
  (a, b) => a.data.chapter - b.data.chapter
);

const apiDesignChapters = (await getCollection("api-design")).sort(
  (a, b) => a.data.chapter - b.data.chapter
);

const frontendChapters = (await getCollection("frontend")).sort(
  (a, b) => a.data.chapter - b.data.chapter
);

const topics = [
  {
    slug: "system-design",
    title: "System Design",
    desc: "From client-server basics to distributed systems at scale. Includes 7 case studies, 2 step-by-step tutorials, and real code in TypeScript and Go.",
    chapters: chapters.length,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
    href: "/topics/system-design/",
  },
  {
    slug: "dsa",
    title: "Data Structures & Algorithms",
    desc: "Patterns that show up in real codebases, not leetcode puzzles. Arrays, trees, graphs, DP — with working TypeScript code.",
    chapters: dsaChapters.length,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    href: "/topics/dsa/",
  },
  {
    slug: "networking",
    title: "Networking Fundamentals",
    desc: "DNS, TCP/IP, TLS, HTTP/2, WebSockets — how the internet actually works.",
    chapters: networkingChapters.length,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
    href: "/topics/networking/",
  },
  {
    slug: "db-internals",
    title: "Database Internals",
    desc: "B-trees, WAL, MVCC, query planning — what happens under the hood.",
    chapters: dbChapters.length,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
    href: "/topics/db-internals/",
  },
  {
    slug: "devops",
    title: "DevOps & Infrastructure",
    desc: "Docker, Kubernetes, CI/CD, IaC — shipping code to production.",
    chapters: devopsChapters.length,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    href: "/topics/devops/",
  },
  {
    slug: "api-design",
    title: "API Design",
    desc: "REST best practices, GraphQL, gRPC, versioning, pagination, and rate limiting.",
    chapters: apiDesignChapters.length,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0118 0"/><path d="M4 14a9 9 0 0018 0"/><line x1="12" y1="11" x2="12" y2="14"/></svg>`,
    href: "/topics/api-design/",
  },
  {
    slug: "frontend",
    title: "Frontend Architecture",
    desc: "Rendering patterns (SSR/SSG/ISR), state management, performance, and accessibility.",
    chapters: frontendChapters.length,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    href: "/topics/frontend/",
  },
];

const upcoming = [
  {
    title: "Operating Systems",
    desc: "Processes, threads, memory management, file systems, and syscalls — how your code actually runs.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>`,
  },
  {
    title: "Security & Cryptography",
    desc: "Auth patterns, OAuth, JWT, encryption, and common vulnerabilities — building secure systems.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: "Distributed Systems",
    desc: "CAP theorem, consensus (Raft/Paxos), CRDTs, vector clocks, and gossip protocols.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><circle cx="5" cy="6" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="5" cy="18" r="2"/><circle cx="19" cy="18" r="2"/><line x1="12" y1="10" x2="5" y2="8"/><line x1="12" y1="10" x2="19" y2="8"/><line x1="12" y1="14" x2="5" y2="16"/><line x1="12" y1="14" x2="19" y2="16"/></svg>`,
  },
  {
    title: "Compiler Design",
    desc: "Lexing, parsing, ASTs, type checking, and code generation — how languages work.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
  },
  {
    title: "Machine Learning Fundamentals",
    desc: "Linear algebra, gradient descent, neural nets, and transformers — for engineers, not researchers.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h4l3-9 4 18 3-9h4"/><circle cx="18" cy="12" r="2"/></svg>`,
  },
  {
    title: "System Design Interview",
    desc: "Structured approach to open-ended design questions with worked examples.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    title: "Software Architecture Patterns",
    desc: "Monolith vs microservices, event-driven, hexagonal, CQRS — choosing the right architecture.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>`,
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Unfold — Complex topics, explained simply</title>
    <meta name="description" content="Unfold breaks down complex engineering topics into clear explanations with real, working code. No jargon. No hand-waving." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cabin+Condensed:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%23fafafa'/><path d='M8 10h16M8 16h12M8 22h8' stroke='%2309090b' stroke-width='2.5' stroke-linecap='round'/></svg>"
    />
  </head>
  <body>

    <!-- Nav -->
    <nav class="landing-nav">
      <a href="/" class="nav-logo">Unfold</a>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <h1 class="hero-title">
          Complex topics,<br/>explained simply.
        </h1>
        <p class="hero-desc">
          Unfold takes hard engineering concepts and breaks them into clear,
          step-by-step explanations with real code you can run.
          Pick a topic and start learning.
        </p>
      </div>
    </section>

    <!-- Available Topics -->
    <section class="topics">
      <div class="topics-inner">
        <div class="section-header">
          <span class="section-label">Available</span>
        </div>

        {topics.map((topic) => (
          <a href={topic.href} class="topic-card">
            <div class="topic-icon" set:html={topic.icon} />
            <div class="topic-info">
              <span class="topic-title">{topic.title}</span>
              <span class="topic-desc">{topic.desc}</span>
            </div>
            <div class="topic-meta">
              <span class="topic-count">{topic.chapters} chapters</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="topic-arrow"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </a>
        ))}

        {upcoming.length > 0 && (
          <Fragment>
            <div class="section-header coming-soon-header">
              <span class="section-label">Coming soon</span>
            </div>
            {upcoming.map((topic) => (
              <div class="topic-card topic-card-disabled">
                <div class="topic-icon" set:html={topic.icon} />
                <div class="topic-info">
                  <span class="topic-title">{topic.title}</span>
                  <span class="topic-desc">{topic.desc}</span>
                </div>
                <div class="topic-meta">
                  <span class="topic-soon-badge">Soon</span>
                </div>
              </div>
            ))}
          </Fragment>
        )}
      </div>
    </section>

    <Footer />

  </body>
</html>

<style>
  body {
    font-family: "Cabin Condensed", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    background: #0f1415;
    color: #fafafa;
    -webkit-font-smoothing: antialiased;
    line-height: 1.6;
    margin: 0;
  }

  ::selection { background: #a3e635; color: #0f1415; }

  /* Nav */
  .landing-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    max-width: 640px;
    margin: 0 auto;
  }

  .nav-logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fafafa;
    text-decoration: none;
    letter-spacing: -0.04em;
  }

  /* Hero */
  .hero {
    padding: 72px 24px 56px;
    text-align: center;
  }

  @media (max-width: 640px) {
    .hero { padding: 48px 16px 36px; }
  }

  .hero-inner {
    max-width: 520px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.045em;
    color: #fafafa;
    margin: 0 0 20px;
  }

  @media (max-width: 640px) {
    .hero-title { font-size: 2rem; }
  }

  .hero-desc {
    font-size: 1.0625rem;
    color: #71717a;
    line-height: 1.7;
    margin: 0;
    max-width: 440px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 640px) {
    .hero-desc { font-size: 0.9375rem; }
  }

  /* Topics */
  .topics {
    padding: 0 24px 80px;
  }

  @media (max-width: 640px) {
    .topics { padding: 0 16px 56px; }
  }

  .topics-inner {
    max-width: 520px;
    margin: 0 auto;
  }

  .section-header {
    padding: 0 0 10px;
  }

  .coming-soon-header {
    margin-top: 32px;
  }

  .section-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #3f3f46;
  }

  /* Topic cards */
  .topic-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    border: 1px solid #1f1f23;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.15s;
    margin-bottom: 8px;
    cursor: pointer;
  }

  a.topic-card:hover {
    background: #16161a;
    border-color: #27272a;
  }

  a.topic-card:hover .topic-arrow {
    transform: translateX(3px);
    color: #a3e635;
  }

  .topic-card-disabled {
    cursor: default;
    opacity: 0.45;
  }

  .topic-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #16161a;
    border-radius: 10px;
    color: #a1a1aa;
    flex-shrink: 0;
  }

  a.topic-card:hover .topic-icon {
    color: #fafafa;
    background: #1f1f23;
  }

  .topic-info {
    flex: 1;
    min-width: 0;
  }

  .topic-title {
    display: block;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #e4e4e7;
    letter-spacing: -0.015em;
  }

  .topic-desc {
    display: block;
    font-size: 0.8125rem;
    color: #52525b;
    margin-top: 2px;
    line-height: 1.45;
  }

  @media (max-width: 640px) {
    .topic-desc {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  }

  .topic-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .topic-count {
    font-size: 0.75rem;
    color: #52525b;
    font-family: "Dank Mono", "Geist Mono", monospace;
    white-space: nowrap;
  }

  .topic-arrow {
    color: #3f3f46;
    transition: all 0.2s;
  }

  .topic-soon-badge {
    font-size: 0.6875rem;
    font-weight: 600;
    color: #52525b;
    background: #18181b;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

</style>
