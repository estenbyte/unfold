---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FrontendSidebar from "../../components/FrontendSidebar.astro";
import { getFrontendChaptersSorted } from "../../data/frontend";

export async function getStaticPaths() {
  const chapters = await getCollection("frontend");
  return chapters.map((ch) => ({
    params: { slug: ch.id },
    props: { chapter: ch },
  }));
}

const { chapter } = Astro.props;
const { Content } = await render(chapter);

const allChapters = await getFrontendChaptersSorted();
const idx = allChapters.findIndex((c) => c.id === chapter.id);
const prev = idx > 0 ? allChapters[idx - 1] : null;
const next = idx < allChapters.length - 1 ? allChapters[idx + 1] : null;

const levelColors: Record<string, string> = {
  beginner: "badge-beginner",
  intermediate: "badge-intermediate",
  advanced: "badge-advanced",
};
---

<BaseLayout title={chapter.data.title} showSidebar={true}>
  <FrontendSidebar slot="sidebar" />

  <!-- Chapter header -->
  <header class="ch-header">
    <div class="ch-meta">
      <a href="/topics/frontend/" class="back-link">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Frontend
      </a>
      <span class="ch-meta-sep"></span>
      <span class={`badge ${levelColors[chapter.data.level]}`}>
        {chapter.data.level}
      </span>
      <span class="ch-meta-sep"></span>
      <span class="ch-meta-item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10" />
          <polyline points="12 6 12 12 16 14" />
        </svg>
        {chapter.data.readingTime}
      </span>
      <span class="ch-meta-sep"></span>
      <span class="ch-meta-item">
        {String(chapter.data.chapter).padStart(2, "0")} / {String(allChapters.length).padStart(2, "0")}
      </span>
    </div>
    <h1 class="ch-title">{chapter.data.title}</h1>
    <p class="ch-subtitle">{chapter.data.subtitle}</p>
  </header>

  <!-- MDX content -->
  <Content />

  <!-- Chapter navigation -->
  <nav class="ch-nav">
    {prev ? (
      <a href={`/frontend/${prev.id}/`} class="ch-nav-link ch-nav-prev">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        <div>
          <span class="ch-nav-label">Previous</span>
          <span class="ch-nav-title">{prev.data.title}</span>
        </div>
      </a>
    ) : <div />}
    {next ? (
      <a href={`/frontend/${next.id}/`} class="ch-nav-link ch-nav-next">
        <div>
          <span class="ch-nav-label">Next</span>
          <span class="ch-nav-title">{next.data.title}</span>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    ) : <div />}
  </nav>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: color 0.15s;
  }
  .back-link:hover {
    color: var(--color-text-primary);
  }

  .ch-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .ch-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .ch-meta-sep {
    width: 1px;
    height: 12px;
    background: var(--color-border);
  }

  .ch-meta-item {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    letter-spacing: 0.01em;
  }

  .ch-title {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.035em;
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
  }

  .ch-subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .ch-nav {
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-subtle);
    gap: 12px;
  }

  .ch-nav-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    text-decoration: none;
    color: var(--color-text-secondary);
    transition: all 0.15s ease;
    max-width: 280px;
  }

  .ch-nav-link:hover {
    border-color: var(--color-text-muted);
    background: var(--color-bg-hover);
  }

  .ch-nav-link svg {
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .ch-nav-prev:hover svg { transform: translateX(-3px); }
  .ch-nav-next:hover svg { transform: translateX(3px); }

  .ch-nav-next {
    text-align: right;
    margin-left: auto;
  }

  .ch-nav-label {
    display: block;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    font-weight: 500;
    margin-bottom: 2px;
  }

  .ch-nav-title {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200px;
  }

  @media (max-width: 640px) {
    .ch-title { font-size: 1.5rem; }
    .ch-nav { flex-direction: column; }
    .ch-nav-link { max-width: 100%; }
    .ch-nav-next { text-align: left; margin-left: 0; }
  }
</style>
